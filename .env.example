# Firebase (Firestore) — server only via Admin SDK
# Option A: paste the full JSON of a Firebase service account key (one line or multiline in quotes).
# Option B (GCP / Cloud Run): omit this and rely on Application Default Credentials with a service account that has Firebase/Firestore access.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Optional: non-default Firestore database id (Firebase Console → Firestore → database picker).
# Omit to use the default "(default)" database.
# FIRESTORE_DATABASE_ID=siatprojects

# Auth.js — generate: openssl rand -base64 32
AUTH_SECRET=

# Public URL of the app (used for OAuth redirects and CAS service URL)
AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth — needs all three; login shows a hint if ENABLE_GOOGLE is true but IDs are missing
ENABLE_GOOGLE=false
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Redirect URI in Google Cloud Console (Web client): {AUTH_URL}/api/auth/callback/google

# SFU CAS — register callback URL with SFU IT; service URL must match exactly
ENABLE_CAS=true

# Comma-separated SFU IDs that are automatically granted GLOBAL_ADMIN on login.
# Add more IDs here for production (e.g. ADMIN_SFU_IDS=akarduni,jsmith).
# Users with GLOBAL_ADMIN role can also be managed at /admin after sign-in.
ADMIN_SFU_IDS=akarduni
