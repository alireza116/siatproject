# MongoDB — optional for local `npm run dev`:
# If MONGODB_URI is unset in development, an embedded MongoDB Memory Server starts automatically
# (first run downloads a small `mongod` binary). Set MONGODB_URI to use Atlas, Docker, or local mongod instead.
# To force failure when URI is missing: DISABLE_IN_MEMORY_MONGO=true
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/videosubmitter
# MONGODB_URI=mongodb://127.0.0.1:27017/videosubmitter
# Docker Compose sets MONGODB_URI to mongodb://mongo:27017/videosubmitter (see docker-compose.yml).

# Auth.js — generate: openssl rand -base64 32
AUTH_SECRET=

# Public URL of the app (used for OAuth redirects and CAS service URL)
AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth — needs all three; login shows a hint if ENABLE_GOOGLE is true but IDs are missing
ENABLE_GOOGLE=false
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Redirect URI in Google Cloud Console (Web client): {AUTH_URL}/api/auth/callback/google

# SFU CAS — register callback URL with SFU IT; service URL must match exactly
ENABLE_CAS=true

# Comma-separated SFU IDs that are automatically granted GLOBAL_ADMIN on login.
# Add more IDs here for production (e.g. ADMIN_SFU_IDS=akarduni,jsmith).
# Users with GLOBAL_ADMIN role can also be managed at /admin after sign-in.
ADMIN_SFU_IDS=akarduni
